# Standard Git ignore settings
# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Runtime data
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/
jspm_packages/

# Build output
dist/
build/
coverage/

# System files
.DS_Store
Thumbs.db
ehthumbs.db
Icon?

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.Python

# Environment
.env
.env.*

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo
*.orig

# Archives
*.zip
*.tar.gz
*.rar
*.7z
